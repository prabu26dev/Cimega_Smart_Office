# ============================================================
# CIMEGA SMART OFFICE v2.0 — Environment Variables Template
#
# PETUNJUK PENGGUNAAN:
#   1. Salin file ini: cp .env.example .env
#   2. Isi semua nilai di file .env dengan kredensial Anda
#   3. JANGAN PERNAH commit file .env ke GitHub!
#      File ini (.env.example) aman untuk di-commit.
# ============================================================

# ─────────────────────────────────────────────────────────────
# 1. FIREBASE CONFIGURATION
#    Dapatkan di: Firebase Console → Project Settings → Web App
# ─────────────────────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# 2. SUPABASE CONFIGURATION
#    Dapatkan di: Supabase Dashboard → Project Settings → API
#    Gunakan Anon/Public Key — BUKAN Service Role Key!
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://your_project_ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
DATABASE_URL=postgresql://postgres:your_password@db.your_project_ref.supabase.co:5432/postgres

# ─────────────────────────────────────────────────────────────
# 3. GOOGLE GEMINI AI
#    Dapatkan gratis di: https://aistudio.google.com/apikey
#    Model yang digunakan: gemini-2.5-flash-preview-04-17
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────────────────────
# 4. GITHUB AUTO-UPDATER
#    Digunakan oleh CimegaUpdater untuk cek & distribusi update
# ─────────────────────────────────────────────────────────────
GITHUB_OWNER=your_github_username
GITHUB_REPO=Cimega_Smart_Office

# ─────────────────────────────────────────────────────────────
# 5. APP CONFIGURATION
# ─────────────────────────────────────────────────────────────
APP_NAME=CIMEGA SMART OFFICE
APP_VERSION=2.0.0
ENV=production
