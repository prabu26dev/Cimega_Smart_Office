# ================================================================
# CIMEGA SMART OFFICE v2.0 — .gitignore
# Electron.js + Firebase + Supabase + Gemini AI
# Target OS: Windows 10/11 (64-bit)
# ================================================================

# ───────────────────────────────────────────────────────────────
# !! KEAMANAN — WAJIB TIDAK DI-UPLOAD KE GITHUB !!
# ───────────────────────────────────────────────────────────────

# Environment variables (kredensial Firebase, Supabase, Gemini)
.env
.env.local
.env.production
.env.development
.env.staging

# Firebase Service Account Keys (digunakan oleh firebase-admin)
serviceAccountKey.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json
google-services.json

# Firebase config dengan hardcoded credentials (gunakan .env + preload.js)
# File ini sudah diganti menjadi dokumentasi saja, tapi tetap diabaikan
# untuk mencegah developer lain meng-hardcode credentials di sini
src/firebase/config.js

# ───────────────────────────────────────────────────────────────
# DEPENDENSI NODE.JS
# ───────────────────────────────────────────────────────────────

node_modules/
.npm/
.pnpm-store/

# ───────────────────────────────────────────────────────────────
# BUILD OUTPUT ELECTRON (Windows only)
# ───────────────────────────────────────────────────────────────

dist/
build/
out/
release/
dist_electron/

# File installer Windows
*.exe
*.msi
*.nsis

# ───────────────────────────────────────────────────────────────
# ASET MEDIA (terlalu besar untuk GitHub)
# ───────────────────────────────────────────────────────────────

# File audio BGM lokal — cukup simpan di mesin admin
assets_music/*.mp3
assets_music/*.wav
assets_music/*.ogg
assets_music/*.aac
assets_music/*.flac
assets_music/*.m4a

# ───────────────────────────────────────────────────────────────
# CACHE & DATA SEMENTARA
# ───────────────────────────────────────────────────────────────

# Cache aplikasi
data_cache/
.cache/
*.cache

# Scratch / file kerja sementara
scratch/

# ───────────────────────────────────────────────────────────────
# LOG FILES
# ───────────────────────────────────────────────────────────────

logs/
*.log
log.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ───────────────────────────────────────────────────────────────
# FILE SISTEM OPERASI
# ───────────────────────────────────────────────────────────────

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS (jika developer menggunakan Mac)
.DS_Store
.AppleDouble
.LSOverride
._*

# ───────────────────────────────────────────────────────────────
# EDITOR & IDE
# ───────────────────────────────────────────────────────────────

# VS Code (settings sensitif, bukan extensions)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# ───────────────────────────────────────────────────────────────
# FILE TEMP & BACKUP
# ───────────────────────────────────────────────────────────────

*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~

# ───────────────────────────────────────────────────────────────
# CATATAN DEVELOPER
# ───────────────────────────────────────────────────────────────
# package-lock.json SENGAJA tidak di-ignore agar versi dependensi
# antar developer/lingkungan tetap konsisten (reproducible builds).
# ================================================================