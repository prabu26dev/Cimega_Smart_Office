# ============================================
# CIMEGA SMART OFFICE - .gitignore
# ============================================

# !! WAJIB - Jangan upload ke GitHub !!
.env
.env.local
.env.production
.env.development
*.env

# Firebase private keys
firebase-adminsdk*.json
serviceAccountKey.json
*-firebase-adminsdk-*.json

# Node modules (besar, tidak perlu diupload)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
out/
release/

# Electron build
dist_electron/
*.exe
*.dmg
*.AppImage
*.deb
*.rpm

# Log files
logs/
*.log
log.txt

# Cache
data_cache/
.cache/
*.cache

# OS files
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# VS Code settings (opsional, bisa dihapus jika ingin share settings)
.vscode/settings.json
.vscode/launch.json

# Python cache (untuk folder AI nanti)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.egg

# AI model files (terlalu besar untuk GitHub)
folder_otak_ai/models/
folder_otak_ai/*.bin
folder_otak_ai/*.gguf
folder_otak_ai/*.ggml

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Package lock (opsional)
# package-lock.json

# Upload setup files (sudah tidak diperlukan setelah setup)
upload_users.html
