{
  "name": "cimega-smart-office",
  "version": "1.0.0",
  "description": "Platform Administrasi Sekolah Cerdas — Kurikulum Merdeka 2025/2026",
  "main": "src/services/electron/main.js",
  "author": "Kang Prabu",
  "scripts": {
    "start": "cls && electron . --no-deprecation",
    "clean": "powershell -Command \"Write-Host 'Cleaning project artifacts...' -ForegroundColor Yellow; Remove-Item -Path 'logs', 'data_cache', 'dist' -Recurse -Force -ErrorAction SilentlyContinue; Write-Host '--- Project is clean! ---' -ForegroundColor Green\"",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --win --x64 --publish never",
    "build:secure": "node src/utils/root_scripts/build-secure.js",
    "release": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.1",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "edge-tts-universal": "^1.4.0",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.8.0",
    "pdfmake": "^0.3.7"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "javascript-obfuscator": "^5.4.1"
  },
  "build": {
    "appId": "com.cimega.smartoffice",
    "productName": "Cimega Smart Office",
    "copyright": "© 2026 Cimega Smart Office",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.md"
    ],
    "extraResources": [
      {
        "from": "src/assets/assets_music",
        "to": "assets_music"
      },
      {
        "from": "src/assets/assets_images",
        "to": "assets_images"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "src/assets/assets_images/Logo SDN Cimega.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "src/assets/assets_images/Logo SDN Cimega.ico",
      "uninstallerIcon": "src/assets/assets_images/Logo SDN Cimega.ico",
      "installerHeaderIcon": "src/assets/assets_images/Logo SDN Cimega.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cimega Smart Office",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "prabu26dev",
      "repo": "Cimega_Smart_Office"
    }
  }
}
