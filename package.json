{
  "name": "Cimega_Smart_Office",
  "version": "1.0.0",
  "description": "Sistem Administrasi Digital SDN Cimega",
  "main": "main.js",
  "author": "Imam Alfida Nurhasby",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --win --x64 --publish never",
    "release": "electron-builder --win --x64 --publish always"
  },
  "dependencies": {
    "electron-log": "^5.4.3",
    "firebase": "^12.10.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.21"
  },
  "build": {
    "appId": "com.cimega.smartoffice",
    "productName": "Cimega Smart Office",
    "copyright": "© 2026 Cimega Smart Office",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!node_modules/.cache/**",
      "!**/*.md",
      "!upload_users.html"
    ],
    "extraResources": [
      {
        "from": "assets_music",
        "to": "assets_music"
      },
      {
        "from": "assets_images",
        "to": "assets_images"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets_images/Logo SDN Cimega.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets_images/Logo SDN Cimega.ico",
      "uninstallerIcon": "assets_images/Logo SDN Cimega.ico",
      "installerHeaderIcon": "assets_images/Logo SDN Cimega.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cimega Smart Office",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "prabu26dev",
      "repo": "Cimega_Smart_Office"
    }
  }
}